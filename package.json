{
  "name": "playwright-qa-automation-demo",
  "version": "1.0.0",
  "description": "End-to-end QA automation framework built with Playwright and TypeScript. Demonstrates Page Object Model, API testing, custom fixtures, CI/CD, and Allure reporting.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:e2e": "playwright test tests/e2e",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report:html": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "report:allure:ci": "allure generate allure-results --clean -o allure-report",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "clean": "rimraf playwright-report allure-results allure-report test-results"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa",
    "automation",
    "page-object-model",
    "api-testing"
  ],
  "author": "Celse Honore Rugira",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.9.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
